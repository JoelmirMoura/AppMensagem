package com.joelmir.chatwifi;

import android.app.Service;
import android.content.Intent;
import android.content.SharedPreferences;
import android.os.IBinder;
import android.util.Log;
import android.os.PowerManager;
import android.net.wifi.WifiManager;

public class ChatService extends Service {

    private PowerManager.WakeLock wakeLock;
    private WifiManager.WifiLock wifiLock;
    private ServerSocket serverSocket;
    private boolean running = false;
    private Thread workerThread;
    private volatile boolean running = false;

    @Override
    public int onStartCommand(Intent intent, int flags, int startId) {

        // 🔥 evita múltiplas threads rodando
        running = false;

        try {
            if (workerThread != null) {
                workerThread.interrupt();
            }
        } catch (Exception ignored) {}

        // =========================
        // 🔋 WAKE LOCK
        // =========================
        try {
            PowerManager pm = (PowerManager) getSystemService(POWER_SERVICE);
            wakeLock = pm.newWakeLock(PowerManager.PARTIAL_WAKE_LOCK, "Chat:WakeLock");
            wakeLock.acquire();
        } catch (Exception e) {
            Log.e("CHAT", "WakeLock error", e);
        }

        // =========================
        // 📶 WIFI LOCK
        // =========================
        try {
            WifiManager wm = (WifiManager) getApplicationContext()
                    .getSystemService(WIFI_SERVICE);

            wifiLock = wm.createWifiLock(WifiManager.WIFI_MODE_FULL, "Chat:WifiLock");
            wifiLock.acquire();
        } catch (Exception e) {
            Log.e("CHAT", "WifiLock error", e);
        }

        SharedPreferences prefs =
                getSharedPreferences("chat", MODE_PRIVATE);

        String modo = prefs.getString("modo", "client");
        String ip = prefs.getString("ip", "");

        ChatHolder.lastError = "";
        ChatHolder.status = "initializing";
        sendStatus();

        // 🔥 fecha conexão anterior
        if (ChatHolder.chat != null) {
            ChatHolder.chat.close();
        }

        ChatHolder.chat = new ChatConnection();

        running = true;

        if ("server".equals(modo)) {
            startServer();
        } else {
            startClient(ip);
        }

        return START_STICKY;
    }

    // =========================
    // 🔵 SERVER
    // =========================
    private void startServer() {

        ChatHolder.chat.setConnectionListener(
                new ChatConnection.ConnectionListener() {
                    @Override
                    public void onClientConnected() {
                        Log.d("CHAT", "Cliente conectou");

                        ChatHolder.status = "connected";
                        sendStatus();
                    }
                });

        workerThread = new Thread(new Runnable() {
            @Override
            public void run() {

                try {

                    ChatHolder.status = "starting_server";
                    sendStatus();

                    ChatHolder.chat.startServer(5000);

                    // 🔥 IP disponível imediatamente
                    ChatHolder.serverIp =
                            NetworkUtil.getWifiIp(getApplicationContext());

                    ChatHolder.status = "server_ready";
                    sendStatus();

                    Log.d("CHAT", "Servidor aguardando cliente...");

                    // 🔥 mantém servidor vivo
                    while (running) {

                        if (ChatHolder.lastError != null &&
                                ChatHolder.lastError.length() > 0) {

                            ChatHolder.status = "error_server";
                            sendStatus();
                            return;
                        }

                        Thread.sleep(1000);
                    }

                } catch (Exception e) {

                    ChatHolder.lastError =
                            e.getClass().getSimpleName() + ": " + e.getMessage();

                    ChatHolder.status = "error_server";
                    sendStatus();
                }
            }
        });

        workerThread.start();
    }

    // =========================
    // 🟢 CLIENT COM RECONEXÃO
    // =========================
    private void startClient(final String ip) {

        workerThread = new Thread(new Runnable() {
            @Override
            public void run() {

                if (ip == null || ip.trim().length() == 0) {
                    ChatHolder.status = "error_client";
                    sendStatus();
                    return;
                }

                while (running) {

                    try {

                        ChatHolder.status = "connecting";
                        sendStatus();

                        boolean ok = ChatHolder.chat.connectToServer(ip.trim(), 5000);

                        if (ok && ChatHolder.chat.isConnected()) {

                            ChatHolder.status = "connected";
                            sendStatus();

                            Log.d("CHAT", "Cliente conectado");

                            // 🔥 fica monitorando conexão
                            while (running && ChatHolder.chat.isConnected()) {
                                Thread.sleep(1000);
                            }

                            Log.d("CHAT", "Conexão caiu, tentando reconectar...");

                            ChatHolder.status = "disconnected";
                            sendStatus();
                        }

                    } catch (Exception e) {

                        ChatHolder.lastError =
                                e.getClass().getSimpleName() + ": " + e.getMessage();

                        ChatHolder.status = "error_client";
                        sendStatus();
                    }

                    // 🔁 aguarda antes de tentar novamente
                    try {
                        Thread.sleep(3000);
                    } catch (Exception ignored) {}
                }
            }
        });

        workerThread.start();
    }

    // =========================
    private void sendStatus() {

        Intent i = new Intent(ChatHolder.ACTION_STATUS);
        i.putExtra("status", ChatHolder.status);
        i.putExtra("error", ChatHolder.lastError);
        sendBroadcast(i);
    }

    // =========================
    @Override
    public void onDestroy() {
        super.onDestroy();

        running = false;

        try {
            if (workerThread != null) {
                workerThread.interrupt();
            }

            if (ChatHolder.chat != null) {
                ChatHolder.chat.close();
            }

            if (wakeLock != null && wakeLock.isHeld()) {
                wakeLock.release();
            }

            if (wifiLock != null && wifiLock.isHeld()) {
                wifiLock.release();
            }

        } catch (Exception e) {
            Log.e("CHAT", "Erro ao destruir service", e);
        }
    }

    @Override
    public IBinder onBind(Intent intent) {
        return null;
    }
}