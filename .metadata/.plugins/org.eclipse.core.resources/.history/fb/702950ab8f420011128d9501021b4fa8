package com.joelmir.chatwifi;

import android.util.Log;

import java.io.*;
import java.net.*;

public class ChatConnection {

    private ServerSocket serverSocket;
    private Socket socket;

    private PrintWriter out;
    private BufferedReader in;

    private volatile boolean connected = false;
    private volatile boolean runningServer = false;
    private volatile boolean listening = false;

    private Thread listenThread;
    private Thread serverThread;

    private MessageListener listener;

    public interface MessageListener {
        void onMessage(String msg);
    }

    public void setMessageListener(MessageListener l) {
        this.listener = l;
    }

    // =========================
    // SERVER
    // =========================
    public boolean startServer(final int port) {

        close();

        runningServer = true;

        serverThread = new Thread(new Runnable() {
            @Override
            public void run() {

                try {

                    serverSocket = new ServerSocket(port);
                    serverSocket.setReuseAddress(true);

                    Log.d("CHAT", "Server iniciado");

                    while (runningServer) {

                        try {

                            socket = serverSocket.accept();

                            if (socket != null) {

                                Log.d("CHAT", "Cliente conectado");

                                setupConnection();
                                return;
                            }

                        } catch (SocketTimeoutException e) {
                            // permite loop contínuo
                        }
                    }

                } catch (Exception e) {
                    Log.e("CHAT", "SERVER ERROR", e);
                }
            }
        });

        serverThread.start();

        return true;
    }

    // =========================
    // CLIENT
    // =========================
    public boolean connectToServer(String ip, int port) {

        try {

            close();

            socket = new Socket();
            socket.connect(new InetSocketAddress(ip, port), 5000);

            setupConnection();

            return true;

        } catch (Exception e) {

            Log.e("CHAT", "CLIENT ERROR", e);
            connected = false;

            return false;
        }
    }

    // =========================
    // SETUP
    // =========================
    private void setupConnection() throws Exception {

        out = new PrintWriter(
                new BufferedWriter(
                        new OutputStreamWriter(socket.getOutputStream())
                ),
                true
        );

        in = new BufferedReader(
                new InputStreamReader(socket.getInputStream())
        );

        connected = true;
        listening = true;

        startListening();
    }

    // =========================
    // LISTENER
    // =========================
    private void startListening() {

        listenThread = new Thread(new Runnable() {
            @Override
            public void run() {

                try {

                    String line;

                    while (listening &&
                            connected &&
                            socket != null &&
                            !socket.isClosed()) {

                        line = in.readLine();

                        if (line == null) break;

                        if (listener != null) {
                            listener.onMessage(line);
                        }
                    }

                } catch (Exception e) {
                    Log.e("CHAT", "LISTEN ERROR", e);
                }
            }
        });

        listenThread.start();
    }

    // =========================
    // SEND (ESTÁVEL)
    // =========================
    public synchronized void sendMessage(String msg) {

        try {

            if (out != null && connected) {

                out.println(msg);
                out.flush();
            }

        } catch (Exception e) {
            Log.e("CHAT", "SEND ERROR", e);
        }
    }

    // =========================
    // CLOSE
    // =========================
    public synchronized void close() {

        connected = false;
        runningServer = false;
        listening = false;

        try {

            if (socket != null) socket.close();
            if (serverSocket != null) serverSocket.close();

        } catch (Exception ignored) {}

        socket = null;
        serverSocket = null;
    }

    public boolean isConnected() {
        return connected && socket != null && socket.isConnected();
    }
}