package com.joelmir.chatwifi;

import android.util.Log;

import java.io.BufferedReader;
import java.io.InputStreamReader;
import java.io.PrintWriter;
import java.net.*;

public class ChatConnection {

    private ServerSocket serverSocket;
    private Socket socket;
    private PrintWriter out;
    private BufferedReader in;

    private ConnectionListener connectionListener;
    private MessageListener listener;
    private DisconnectListener disconnectListener;

    private Thread heartbeatThread;
    private Thread listenThread;

    private volatile boolean connected = false;

    private DatagramSocket discoverySocket;

    // =========================
    // INTERFACES
    // =========================
    public interface ConnectionListener {
        void onConnected();
    }

    public interface MessageListener {
        void onMessage(String msg);
    }

    public interface DisconnectListener {
        void onDisconnected();
    }

    public void setMessageListener(MessageListener listener) {
        this.listener = listener;
    }

    public void setConnectionListener(ConnectionListener listener) {
        this.connectionListener = listener;
    }

    public void setDisconnectListener(DisconnectListener listener) {
        this.disconnectListener = listener;
    }

    // =========================
    // DISCOVERY SERVER
    // =========================
    public void startDiscoveryServer() {

        new Thread(() -> {
            try {
                discoverySocket = new DatagramSocket(8888);

                Log.d("CHAT", "🔵 UDP Server ativo");

                byte[] buffer = new byte[256];

                while (!discoverySocket.isClosed()) {

                    DatagramPacket packet = new DatagramPacket(buffer, buffer.length);
                    discoverySocket.receive(packet);

                    String msg = new String(packet.getData(), 0, packet.getLength());

                    Log.d("CHAT", "📩 UDP recebido: " + msg);

                    if ("DISCOVER_SERVER".equals(msg)) {

                        byte[] resp = "SERVER_HERE".getBytes();

                        DatagramPacket response = new DatagramPacket(
                                resp,
                                resp.length,
                                packet.getAddress(),
                                packet.getPort()
                        );

                        discoverySocket.send(response);

                        Log.d("CHAT", "✅ Respondeu discovery");
                    }
                }

            } catch (Exception e) {
                Log.d("CHAT", "UDP server finalizado: " + e.getMessage());
            }
        }).start();
    }

    // =========================
    // DISCOVERY CLIENT
    // =========================
    public String discoverServer() {

        DatagramSocket ds = null;

        try {
            ds = new DatagramSocket();
            ds.setBroadcast(true);
            ds.setSoTimeout(2500);

            byte[] send = "DISCOVER_SERVER".getBytes();

            DatagramPacket packet = new DatagramPacket(
                    send,
                    send.length,
                    InetAddress.getByName("255.255.255.255"),
                    8888
            );

            ds.send(packet);

            byte[] recv = new byte[256];
            DatagramPacket response = new DatagramPacket(recv, recv.length);

            ds.receive(response);

            String msg = new String(response.getData(), 0, response.getLength());

            if ("SERVER_HERE".equals(msg)) {
                return response.getAddress().getHostAddress();
            }

        } catch (Exception e) {
            Log.d("CHAT", "❌ discover falhou: " + e.getMessage());
        } finally {
            if (ds != null) ds.close();
        }

        return null;
    }

    // =========================
    // SERVER
    // =========================
    public synchronized boolean startServer(int port) {

        try {
            close();

            serverSocket = new ServerSocket(port);

            Log.d("CHAT", "🟢 Aguardando cliente...");

            socket = serverSocket.accept();

            Log.d("CHAT", "🟢 Cliente conectado");

            setupConnection();

            return true;

        } catch (Exception e) {
            Log.d("CHAT", "❌ server erro: " + e.getMessage());
            return false;
        }
    }

    // =========================
    // CLIENT
    // =========================
    public synchronized boolean connectToServer(String ip, int port) {

        try {
            close();

            socket = new Socket();
            socket.connect(new InetSocketAddress(ip, port), 4000);

            Log.d("CHAT", "🟢 conectado ao server");

            setupConnection();

            return true;

        } catch (Exception e) {
            Log.d("CHAT", "❌ client erro: " + e.getMessage());
            return false;
        }
    }

    // =========================
    // SETUP
    // =========================
    private void setupConnection() throws Exception {

        out = new PrintWriter(socket.getOutputStream(), true);
        in = new BufferedReader(new InputStreamReader(socket.getInputStream()));

        connected = true;

        if (connectionListener != null) {
            connectionListener.onConnected();
        }

        startListening();
        startHeartbeat();
    }

    // =========================
    // LISTEN
    // =========================
    private void startListening() {

        listenThread = new Thread(() -> {

            try {
                String line;

                while (connected &&
                        socket != null &&
                        !socket.isClosed() &&
                        (line = in.readLine()) != null) {

                    if ("__PING__".equals(line)) continue;

                    if (listener != null) {
                        listener.onMessage(line);
                    }
                }

            } catch (Exception e) {
                Log.d("CHAT", "listen erro: " + e.getMessage());
            } finally {
                close();
            }
        });

        listenThread.start();
    }

    // =========================
    // SEND
    // =========================
    public synchronized void sendMessage(String msg) {

        if (out != null && connected) {
            out.println(msg);
        }
    }

    // =========================
    // HEARTBEAT
    // =========================
    private void startHeartbeat() {

        heartbeatThread = new Thread(() -> {

            try {
                while (connected) {

                    if (out != null) {
                        out.println("__PING__");
                    }

                    Thread.sleep(4000);
                }

            } catch (Exception e) {
                connected = false;
                notifyDisconnect();
            }
        });

        heartbeatThread.start();
    }

    // =========================
    // CLOSE
    // =========================
    public synchronized void close() {

        connected = false;

        try {
            if (discoverySocket != null) discoverySocket.close();
            if (in != null) in.close();
            if (out != null) out.close();
            if (socket != null) socket.close();
            if (serverSocket != null) serverSocket.close();

        } catch (Exception ignored) {}

        discoverySocket = null;
        in = null;
        out = null;
        socket = null;
        serverSocket = null;
    }

    public boolean isConnected() {
        return connected;
    }
}